{
    "$schema": "https://raw.githubusercontent.com/infection/infection/master/resources/schema.json",

    "source": {
        "directories": ["src"],
        // Exclure les fichiers sans logique métier (pure déclaration de services, config)
        "excludes": [
            "src/GhostTreesBundle.php",
            "src/DependencyInjection"
        ]
    },

    "testFramework": "phpunit",

    "testFrameworkOptions": "--testdox",

    // Répertoires des logs de mutation (ignorés par git via .gitignore)
    "logs": {
        "text": "coverage/infection.log",
        "html": "coverage/infection.html",
        "json": "coverage/infection.json",
        "summary": "coverage/infection-summary.log",
        "perMutator": "coverage/infection-per-mutator.md"
    },

    // Seuils de qualité
    // MSI (Mutation Score Indicator) >= 70 % : objectif minimal
    // Covered MSI >= 85 % : mutations sur code couvert par des tests
    "minMsi": 70,
    "minCoveredMsi": 85,

    "mutators": {
        // ── Comparaisons ─────────────────────────────────────────────────────
        // @comparison n'existe pas dans le schéma — on décompose en trois groupes
        // valides qui couvrent les mêmes cas : égalité, bornes et négation.
        "@equal": true,
        "@conditional_boundary": true,
        "@conditional_negotiation": true,

        // ── Valeurs de retour ────────────────────────────────────────────────
        // @return_value couvre TrueValue, FalseValue, NewObject, This, etc.
        // Return_ n'existe pas dans le schéma — on utilise le groupe complet.
        "@return_value": true,

        // ── Nombres entiers ──────────────────────────────────────────────────
        // OneZeroInteger n'existe pas — on utilise les mutateurs individuels
        "DecrementInteger": true,
        "IncrementInteger": true,

        // ── Logique booléenne ────────────────────────────────────────────────
        "LogicalAnd": true,
        "LogicalOr": true,
        "LogicalNot": true,

        // ── Opérateurs null-safe ─────────────────────────────────────────────
        // "Nullsafe" n'existe pas — on utilise les deux mutateurs distincts
        "NullSafeMethodCall": true,
        "NullSafePropertyCall": true,

        // ── Suppression d'appels ─────────────────────────────────────────────
        "MethodCallRemoval": {
            "ignore": [
                // Le dispatcher d'événements est optionnel par nature ;
                // supprimer l'appel ne doit pas casser les tests métier.
                "EricGansa\\GhostTreesBundle\\Incarnator\\GhostIncarnator::dispatch"
            ]
        },

        // ── Désactivé ────────────────────────────────────────────────────────
        // Les tests de cycle/profondeur couvrent déjà tous les chemins throw.
        "Throw_": false
    }
}
