{
    "$schema": "https://raw.githubusercontent.com/infection/infection/master/resources/schema.json",

    "source": {
        "directories": ["src"],
        // Exclure les fichiers sans logique métier (pure déclaration de services, config)
        "excludes": [
            "src/GhostTreesBundle.php",
            "src/DependencyInjection"
        ]
    },

    "testFramework": "phpunit",

    "testFrameworkOptions": "--testdox",

    // Répertoires des logs de mutation (ignorés par git via .gitignore)
    "logs": {
        "text": "coverage/infection.log",
        "html": "coverage/infection.html",
        "json": "coverage/infection.json",
        "summary": "coverage/infection-summary.log",
        "perMutator": "coverage/infection-per-mutator.md"
    },

    // Seuils de qualité
    // MSI (Mutation Score Indicator) >= 70 % : objectif minimal
    // Covered MSI >= 85 % : mutations sur code couvert par des tests
    "minMsi": 70,
    "minCoveredMsi": 85,

    // Mutateurs actifs — liste explicite pour éviter les faux positifs
    "mutators": {
        // Opérateurs de comparaison
        "@equal": true,
        "@comparison": true,

        // Valeurs retournées
        "TrueValue": true,
        "FalseValue": true,
        "OneZeroInteger": true,

        // Logique
        "Identical": true,
        "NotIdentical": true,
        "LogicalAnd": true,
        "LogicalOr": true,
        "LogicalNot": true,
        "Nullsafe": true,

        // Return statements
        "Return_": true,

        // Suppression de lignes
        "MethodCallRemoval": {
            "ignore": [
                // Les dispatchers d'événements sont optionnels par nature ;
                // supprimer l'appel ne doit pas casser les tests métier.
                "EricGansa\\GhostTreesBundle\\Incarnator\\GhostIncarnator::dispatch"
            ]
        },

        // Ne pas muter les exceptions : les tests de cycle/profondeur
        // vérifient déjà ces chemins.
        "Throw_": false
    }
}
